# --- App config ---
# Docker 内では /data がマウントされる named volume。ローカル開発用に書き換えても OK。
DATABASE_URL=sqlite:///data/db.sqlite
GOOGLE_OAUTH_CLIENT_ID=...
GOOGLE_OAUTH_CLIENT_SECRET=...
# JWT 署名鍵 (HS256, decode 後 32 バイト以上)。生成は `openssl rand -base64 32`
JWT_SIGNING_KEY_v1=base64-encoded-32-bytes
# Vertex AI (Gemini) 設定。認証は ADC (本番は GCE Instance SA、ローカルは
# `gcloud auth application-default login`)。API key 不要。
VERTEX_PROJECT=<your-gcp-project>
VERTEX_LOCATION=us-central1
MODEL_EXTRACT=gemini-2.5-flash
MODEL_SYNTH=gemini-2.5-pro
TRUSTED_PROXY_COUNT=1
BIND_ADDR=0.0.0.0:8080

# --- Deploy config ---
# 公開ドメイン (e.g. 34-146-12-34.nip.io)。Caddy が Let's Encrypt 経由で証明書を取る。
PUBLIC_DOMAIN=34-146-12-34.nip.io
# サーバが自分自身を識別する URL (OAuth issuer / redirect URI 構築に使用)
PUBLIC_URL=https://34-146-12-34.nip.io

# (注意) docker compose の project 名 (named volume 接頭辞) は `.env` からは
# 反映されない。compose CLI に `--project-name llm-memory-extention` フラグを
# 毎回付ける (deploy README 参照)。

# --- litestream backup ---
# GCS バケット名 (project prefix 推奨)。VM の instance SA が objectAdmin。
# `<your-gcp-project>-memory-backup` のように自分の project ID で置換すること。
LITESTREAM_BUCKET=<your-gcp-project>-memory-backup
